# Base de datos Turso
DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Para desarrollo local con SQLite, usa:
# DATABASE_URL="file:./dev.db"

# SMTP Configuration (para envío de emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password"

# Email remitente
EMAIL_FROM="noreply@madrugadasalvada.com"

# Webhook de Make
MAKE_WEBHOOK_URL="https://hook.us2.make.com/tu-webhook"

# URL de página de ventas (redirección en 3ra visita)
SALES_PAGE_URL="https://tu-pagina-ventas.com"

# URL de tu sitio (para producción)
NEXT_PUBLIC_APP_URL="https://tu-sitio.netlify.app"
